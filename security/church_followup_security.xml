<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_church_followup" model="ir.module.category">
        <field name="name">Suivi Évangélisation</field>
        <field name="description">Gestion du suivi d'évangélisation des églises</field>
        <field name="sequence">30</field>
    </record>

    <!-- Privilege -->
    <record id="privilege_church_followup" model="res.groups.privilege">
        <field name="name">Suivi Évangélisation</field>
        <field name="category_id" ref="module_category_church_followup"/>
    </record>

    <!-- Groups -->
    <record id="group_church_user" model="res.groups">
        <field name="name">Utilisateur Église</field>
        <field name="privilege_id" ref="privilege_church_followup"/>
    </record>

    <record id="group_church_manager" model="res.groups">
        <field name="name">Responsable Église</field>
        <field name="privilege_id" ref="privilege_church_followup"/>
        <field name="implied_ids" eval="[(4, ref('group_church_user'))]"/>
    </record>

    <record id="group_church_admin" model="res.groups">
        <field name="name">Super Administrateur Église</field>
        <field name="privilege_id" ref="privilege_church_followup"/>
        <field name="implied_ids" eval="[(4, ref('group_church_manager'))]"/>
    </record>

    <!-- Access rules: all data visible to all church groups -->
    <!-- Fine-grained access is enforced at the mobile API level (cross-church validation) -->
    <record id="rule_church_church_global" model="ir.rule">
        <field name="name">Église : accès global</field>
        <field name="model_id" ref="model_church_church"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_church_user'))]"/>
    </record>

    <record id="rule_church_member_global" model="ir.rule">
        <field name="name">Membre : accès global</field>
        <field name="model_id" ref="model_church_member"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_church_user'))]"/>
    </record>

    <record id="rule_church_followup_global" model="ir.rule">
        <field name="name">Suivi : accès global</field>
        <field name="model_id" ref="model_church_followup"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_church_user'))]"/>
    </record>

    <record id="rule_church_evangelist_global" model="ir.rule">
        <field name="name">Évangéliste : accès global</field>
        <field name="model_id" ref="model_church_evangelist"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_church_user'))]"/>
    </record>
</odoo>
