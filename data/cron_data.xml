<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rappel hebdomadaire pour les évangélistes -->
        <record id="cron_followup_reminder" model="ir.cron">
            <field name="name">Rappel de suivi hebdomadaire</field>
            <field name="model_id" ref="model_church_followup"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Vérification fin de suivi -->
        <record id="cron_followup_check_end" model="ir.cron">
            <field name="name">Vérification fin de période de suivi</field>
            <field name="model_id" ref="model_church_followup"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_followup_end()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
