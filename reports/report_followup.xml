<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_followup" model="ir.actions.report">
        <field name="name">Rapport de suivi</field>
        <field name="model">church.followup</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">church_followup.report_followup_template</field>
        <field name="report_file">church_followup.report_followup_template</field>
        <field name="binding_model_id" ref="model_church_followup"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_followup_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Rapport de Suivi d'Évangélisation</h2>
                        <hr/>

                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Référence :</strong> <t t-esc="doc.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Église :</strong> <t t-esc="doc.church_id.name"/>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Évangéliste :</strong> <t t-esc="doc.evangelist_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Personne suivie :</strong> <t t-esc="doc.member_id.display_name_custom"/>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-4">
                                <strong>Du :</strong> <t t-esc="doc.start_date" t-options="{'widget': 'date'}"/>
                            </div>
                            <div class="col-4">
                                <strong>Au :</strong> <t t-esc="doc.end_date" t-options="{'widget': 'date'}"/>
                            </div>
                            <div class="col-4">
                                <strong>État :</strong> <t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                            </div>
                        </div>

                        <h4 class="mt-4">Rapports Hebdomadaires</h4>
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th>Semaine</th>
                                    <th>Date</th>
                                    <th>Présence culte</th>
                                    <th>Appel</th>
                                    <th>Visite</th>
                                    <th>État spirituel</th>
                                    <th>Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.week_ids" t-as="week">
                                    <tr>
                                        <td><t t-esc="week.week_number"/></td>
                                        <td><t t-esc="week.date" t-options="{'widget': 'date'}"/></td>
                                        <td><t t-if="week.sunday_attendance">✓</t><t t-else="">✗</t></td>
                                        <td><t t-if="week.call_made">✓</t><t t-else="">✗</t></td>
                                        <td><t t-if="week.visit_made">✓</t><t t-else="">✗</t></td>
                                        <td><t t-esc="dict(week._fields['spiritual_state'].selection).get(week.spiritual_state, '-')"/></td>
                                        <td><t t-esc="week.score"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="doc.notes">
                            <h4 class="mt-3">Notes</h4>
                            <p><t t-esc="doc.notes"/></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
