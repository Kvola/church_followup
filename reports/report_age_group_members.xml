<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_age_group_members" model="ir.actions.report">
        <field name="name">Liste des groupes d'âge et membres</field>
        <field name="model">church.age.group</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">church_followup.report_age_group_members_template</field>
        <field name="report_file">church_followup.report_age_group_members_template</field>
        <field name="binding_model_id" ref="model_church_age_group"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_age_group_members_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center">Liste des Groupes d'Âge et Membres</h2>
                    <hr/>

                    <t t-foreach="docs" t-as="group">
                        <div class="mb-4">
                            <h4>
                                <t t-esc="group.name"/>
                                <small class="text-muted">
                                    (<t t-esc="group.member_count"/> membres)
                                </small>
                            </h4>
                            <div class="row mb-2">
                                <div class="col-4">
                                    <strong>Type :</strong> <t t-esc="dict(group._fields['group_type'].selection).get(group.group_type, '-')"/>
                                </div>
                                <div class="col-4">
                                    <strong>Sexe :</strong> <t t-esc="dict(group._fields['gender'].selection).get(group.gender, '-')"/>
                                </div>
                                <div class="col-4">
                                    <strong>Responsable :</strong> <t t-esc="group.leader_name or '-'"/>
                                </div>
                            </div>

                            <table class="table table-bordered table-sm">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Nom</th>
                                        <th>Prénom</th>
                                        <th>Téléphone</th>
                                        <th>Âge</th>
                                        <th>Sexe</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="group.member_ids" t-as="member">
                                        <tr>
                                            <td><t t-esc="member_index + 1"/></td>
                                            <td><t t-esc="member.name"/></td>
                                            <td><t t-esc="member.first_name"/></td>
                                            <td><t t-esc="member.phone or '-'"/></td>
                                            <td><t t-esc="member.age"/></td>
                                            <td><t t-esc="dict(member._fields['gender'].selection).get(member.gender, '-')"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>
