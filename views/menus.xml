    <menuitem id="menu_church_evangelist"
              name="Évangélistes"
              parent="menu_church_evangelism"
              action="action_church_evangelist"
              sequence="20"/>

    <menuitem id="menu_church_member_new"
              name="Nouvelles personnes"
              parent="menu_church_evangelism"
