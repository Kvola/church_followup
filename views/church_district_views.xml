<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_church_district_form" model="ir.ui.view">
        <field name="name">church.district.form</field>
        <field name="model">church.district</field>
        <field name="arch" type="xml">
            <form string="Quartier">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du quartier"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="church_id"/>
                            <field name="city"/>
                        </group>
                        <group>
                            <field name="prayer_cell_id"/>
                            <field name="member_count"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description du quartier..."/>
                    <notebook>
                        <page string="Membres du quartier" name="page_members">
                            <field name="member_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="first_name"/>
                                    <field name="phone" widget="phone"/>
                                    <field name="prayer_cell_id"/>
                                    <field name="member_type" widget="badge"
                                           decoration-info="member_type == 'new'"
                                           decoration-warning="member_type == 'in_followup'"
                                           decoration-success="member_type == 'integrated'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_church_district_list" model="ir.ui.view">
        <field name="name">church.district.list</field>
        <field name="model">church.district</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="church_id" optional="hide"/>
                <field name="city"/>
                <field name="prayer_cell_id"/>
                <field name="member_count"/>
            </list>
        </field>
    </record>

    <record id="view_church_district_search" model="ir.ui.view">
        <field name="name">church.district.search</field>
        <field name="model">church.district</field>
        <field name="arch" type="xml">
            <search string="Rechercher un quartier">
                <field name="name"/>
                <field name="city"/>
                <field name="church_id"/>
                <field name="prayer_cell_id"/>
                <separator/>
                <filter name="filter_no_cell" string="Sans cellule" domain="[('prayer_cell_id', '=', False)]"/>
                <filter name="filter_archived" string="Archivés" domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_church" string="Église" context="{'group_by': 'church_id'}"/>
                    <filter name="group_city" string="Ville" context="{'group_by': 'city'}"/>
                    <filter name="group_cell" string="Cellule" context="{'group_by': 'prayer_cell_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_church_district" model="ir.actions.act_window">
        <field name="name">Quartiers</field>
        <field name="res_model">church.district</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_church_district_search"/>
    </record>
</odoo>
