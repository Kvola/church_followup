<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_church_mobile_user_form" model="ir.ui.view">
        <field name="name">church.mobile.user.form</field>
        <field name="model">church.mobile.user</field>
        <field name="arch" type="xml">
            <form string="Utilisateur mobile">
                <header>
                    <button name="action_share_credentials" string="📋 Partager identifiants" type="object" class="btn-primary" invisible="not pin"/>
                    <button name="action_regenerate_pin" string="Régénérer le PIN" type="object" class="btn-secondary" confirm="Êtes-vous sûr de vouloir régénérer le PIN ?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom complet"/></h1>
                    </div>
                    <group>
                        <group string="Connexion">
                            <field name="phone"/>
                            <field name="pin"/>
                            <field name="role"/>
                        </group>
                        <group string="Affectation">
                            <field name="church_id"/>
                            <field name="evangelist_id" invisible="role != 'evangelist'"/>
                            <field name="prayer_cell_id" invisible="role != 'cell_leader'"/>
                            <field name="age_group_id" invisible="role != 'group_leader'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_church_mobile_user_list" model="ir.ui.view">
        <field name="name">church.mobile.user.list</field>
        <field name="model">church.mobile.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="role" widget="badge"/>
                <field name="church_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_church_mobile_user" model="ir.actions.act_window">
        <field name="name">Utilisateurs mobiles</field>
        <field name="res_model">church.mobile.user</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
