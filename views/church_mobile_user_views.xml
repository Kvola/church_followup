<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_church_mobile_user_form" model="ir.ui.view">
        <field name="name">church.mobile.user.form</field>
        <field name="model">church.mobile.user</field>
        <field name="arch" type="xml">
            <form string="Utilisateur mobile">
                <header>
                    <button name="action_share_credentials" string="Partager identifiants" type="object"
                            class="btn-primary" invisible="not pin" icon="fa-share-alt"/>
                    <button name="action_regenerate_pin" string="Régénérer le PIN" type="object"
                            class="btn-secondary" confirm="Êtes-vous sûr de vouloir régénérer le PIN ?" icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom complet"/></h1>
                    </div>
                    <group>
                        <group string="Connexion">
                            <field name="phone" widget="phone"/>
                            <field name="pin"/>
                            <field name="role"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Affectation">
                            <field name="church_id" required="role != 'super_admin'"/>
                            <field name="evangelist_id" invisible="role != 'evangelist'"/>
                            <field name="prayer_cell_id" invisible="role != 'cell_leader'"/>
                            <field name="age_group_id" invisible="role != 'group_leader'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_church_mobile_user_list" model="ir.ui.view">
        <field name="name">church.mobile.user.list</field>
        <field name="model">church.mobile.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone" widget="phone"/>
                <field name="role" widget="badge"
                       decoration-info="role == 'evangelist'"
                       decoration-success="role == 'super_admin'"
                       decoration-warning="role in ('cell_leader', 'group_leader')"
                       decoration-primary="role == 'manager'"/>
                <field name="church_id" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_church_mobile_user_search" model="ir.ui.view">
        <field name="name">church.mobile.user.search</field>
        <field name="model">church.mobile.user</field>
        <field name="arch" type="xml">
            <search string="Rechercher un utilisateur mobile">
                <field name="name"/>
                <field name="phone"/>
                <field name="church_id"/>
                <separator/>
                <filter name="filter_evangelist" string="Évangélistes" domain="[('role', '=', 'evangelist')]"/>
                <filter name="filter_cell_leader" string="Resp. cellules" domain="[('role', '=', 'cell_leader')]"/>
                <filter name="filter_group_leader" string="Resp. groupes" domain="[('role', '=', 'group_leader')]"/>
                <filter name="filter_manager" string="Responsables" domain="[('role', '=', 'manager')]"/>
                <filter name="filter_admin" string="Super admin" domain="[('role', '=', 'super_admin')]"/>
                <separator/>
                <filter name="filter_active" string="Actifs" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactifs" domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_role" string="Rôle" context="{'group_by': 'role'}"/>
                    <filter name="group_church" string="Église" context="{'group_by': 'church_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_church_mobile_user" model="ir.actions.act_window">
        <field name="name">Utilisateurs mobiles</field>
        <field name="res_model">church.mobile.user</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_church_mobile_user_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun utilisateur mobile
            </p>
            <p>
                Les comptes mobiles sont créés automatiquement lors de l'ajout d'évangélistes ou via les cellules/groupes.
            </p>
        </field>
    </record>
</odoo>
